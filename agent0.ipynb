   "source": [
    "import os\n",
    "from openai import AsyncOpenAI\n",
    "from agents import Agent, Runner, OpenAIChatCompletionsModel, set_default_openai_client, set_default_openai_api\n",
    "\n",
    "os.environ[\"OPENAI_AGENTS_DISABLE_TRACING\"] = \"1\"\n",
    "\n",
    "client = AsyncOpenAI(\n",
    "    api_key= OPENROUTER_API_KEY = os.getenv(\"OPENROUTER_API_KEY\"),\n",
    "    base_url=\"https://openrouter.ai/api/v1\"\n",
    ")\n",
    "\n",
    "# Both of these are needed\n",
    "set_default_openai_client(client)\n",
    "set_default_openai_api(\"chat_completions\")  # ← forces chat completions, not /responses\n",
    "\n",
    "first_agent = Agent(\n",
    "    name=\"General Agent\",\n",
    "    instructions=\"You are a helpful assistant. Answer questions clearly.\",\n",
    "    model=OpenAIChatCompletionsModel(\n",
    "        model='openrouter/free',\n",
    "        openai_client=client\n",
    "    )\n",
    ")\n",
    "\n",
    "first_runner = await Runner.run(first_agent, \"Who is the current US President\")\n",
    "print(first_runner.final_output)"
   ]
  },
