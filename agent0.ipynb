   "source": [
    "import os\n",
    "from openai import AsyncOpenAI\n",
    "from agents import Agent, Runner, OpenAIChatCompletionsModel, RunConfig, ModelProvider\n",
    "\n",
    "# Set this up once at the top of your notebook\n",
    "class OpenRouterProvider(ModelProvider):\n",
    "    def get_model(self, model_name: str):\n",
    "        client = AsyncOpenAI(\n",
    "            base_url=\"https://openrouter.ai/api/v1\",\n",
    "            api_key=api_key=os.getenv("OPENROUTER_API_KEY"),
    "        )\n",
    "        return OpenAIChatCompletionsModel(model=model_name, openai_client=client)\n",
    "\n",
    "openrouter = RunConfig(model_provider=OpenRouterProvider())"
   ]
  },
