   "source": [
    "import os\n",
    "os.environ[\"OPENAI_API_KEY\"] = OPENROUTER_API_KEY = os.getenv(\"OPENROUTER_API_KEY\")\n",
    "os.environ[\"OPENAI_BASE_URL\"] = \"https://openrouter.ai/api/v1\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 40,
   "id": "079d1349",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Here’s a summary of all your orders and their current statuses:\n",
      "\n",
      "| Order ID | Item   | Current Status                         |\n",
      "|----------|--------|----------------------------------------|\n",
      "| order_1  | Laptop | Delivery in Progress                   |\n",
      "| order_2  | Mouse  | Awaiting Payment Confirmation           |\n",
      "\n",
      "If you need any more details or assistance, just let me know!\n"
     ]
    }
   ],
   "source": [
    "import os\n",
    "os.environ[\"OPENAI_AGENTS_DISABLE_TRACING\"] = \"1\"\n",
    "\n",
    "from openai import AsyncOpenAI\n",
    "from agents import Agent, Runner, OpenAIChatCompletionsModel, function_tool\n",
    "\n",
    "client = AsyncOpenAI(\n",
    "    api_key= os.getenv("OPENROUTER_API_KEY"),
    "    base_url=\"https://openrouter.ai/api/v1\"\n",
    ")\n",
    "\n",
    "@function_tool\n",
    "def get_user(email: str) -> str:\n",
    "    \"\"\"Look up the User ID from email.\"\"\"\n",
    "    return \"user_123\"\n",
    "\n",
    "@function_tool\n",
    "def get_user_orders(user_id: str) -> str:\n",
    "    \"\"\"Get orders for User ID.\"\"\"\n",
    "    return \"Order 1: Laptop, Order 2: Mouse\"\n",
    "\n",
    "@function_tool\n",
    "def get_order_status(order_id: str) -> str:\n",
    "    \"\"\"Get status of an order.\"\"\"\n",
    "    return \"Order 1: Delivery in Progress, Order 2: Awaiting Payment Confirmation\"\n",
    "\n",
    "order_agent = Agent(\n",
    "    name=\"Order Assistant\",\n",
    "    instructions=\"\"\"Help users check their order status. Follow these steps strictly:\n",
    "1. Use the user's email to get their User ID\n",
    "2. Use the User ID to get all their orders\n",
    "3. Get the status of ALL orders automatically without asking\n",
    "4. Present a clear summary of every order and its status\"\"\",\n",
    "    model=OpenAIChatCompletionsModel(\n",
    "        model=\"openai/gpt-oss-120b\",\n",
    "        openai_client=client\n",
    "    ),\n",
    "    tools=[get_user, get_user_orders, get_order_status]\n",
    ")\n",
    "\n",
    "runner = await Runner.run(\n",
    "    order_agent,\n",
    "    \"My email is miracle@gmail.com. Get all my orders and their statuses automatically.\"\n",
    ")\n",
    "print(runner.final_output)"
   ]
  }
 ],
